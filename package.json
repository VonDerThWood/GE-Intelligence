{
  "name": "genius-ge-intelligence",
  "productName": "GEnius",
  "version": "1.8.3",
  "description": "RuneScape 3 Grand Exchange Market Intelligence",
  "main": "src/main.js",
  "author": "VonDerThWood",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "prebuild": "node scripts/sync-overrides.js",
    "build": "electron-builder --win --x64",
    "build:dir": "electron-builder --win --x64 --dir",
    "postinstall": "electron-builder install-app-deps"
  },
  "devDependencies": {
    "@capacitor/assets": "^3.0.5",
    "@capacitor/cli": "^8.4.1",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "esbuild": "^0.28.1",
    "path-browserify": "^1.0.1"
  },
  "build": {
    "appId": "com.vonderthwood.genius",
    "productName": "GEnius",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "assets/**/*",
      "node_modules/**/*"
    ],
    "asarUnpack": [
      "src/backend-js/data/**/*"
    ],
    "extraResources": [
      {
        "from": "assets/",
        "to": "assets/",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "GEnius",
      "allowElevation": true,
      "include": "build/installer.nsh"
    }
  },
  "dependencies": {
    "@capacitor/android": "^8.4.1",
    "@capacitor/app": "^8.1.0",
    "@capacitor/background-runner": "^3.0.0",
    "@capacitor/core": "^8.4.1",
    "@capacitor/filesystem": "^8.1.2",
    "@capacitor/local-notifications": "^8.2.0",
    "@capacitor/preferences": "^8.0.1"
  }
}
